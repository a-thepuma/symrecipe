{% extends "base.html.twig" %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}SymRecipe - Création d'une recette
{% endblock %}

{% block body %}
	<div class="container mb-5">

		<h1 class="mt-4 text-black">Création d'une recette</h1>

		<div class="alert alert-danger">
			{{ form_errors(form) }}
		</div>
		
		{{ form_start(form) }}
		{{ form_row(form.name) }}
		{{ form_row(form.time) }}
		{{ form_row(form.nbPersons) }}
		{{ form_row(form.difficulty) }}
		{{ form_row(form.description) }}
		{{ form_row(form.price) }}
		{{ form_row(form.isFavorite) }}

		<div class="form-group mt-4">
			{{ form_label(form.ingredients, 'Ingrédients', {'label_attr': {'class': 'form-label'}}) }}

			<div class="dropdown">
				<button class="btn btn-outline-secondary dropdown-toggle w-100 text-start bg-white text-dark" type="button" id="dropdownIngredients" data-bs-toggle="dropdown" aria-expanded="false" style="border: 1px solid #dee2e6; height: calc(3.5rem + 2px);">
					Choisir les ingrédients...
				</button>

				<ul class="dropdown-menu w-100 p-3" aria-labelledby="dropdownIngredients" style="max-height: 250px; overflow-y: auto;">

					{% for child in form.ingredients %}
						<li class="dropdown-item-text">
							<div class="form-check">
								{{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
								{{ form_label(child, null, {'label_attr': {'class': 'form-check-label text-dark'}}) }}
							</div>
						</li>
					{% endfor %}
				</ul>
			</div>
			<div class="text-danger">{{ form_errors(form.ingredients) }}</div>
		</div>

		<button type="submit" class="btn btn-warning mt-4 w-100">Valider</button>

		{{ form_end(form) }}
	</div>
	 <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
